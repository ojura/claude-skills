# markdown-latex-report
# Builds a polished PDF from a single Markdown file via pandoc + lualatex,
# with a custom Lua filter (smart tables + code line-breaking), a typographic
# preamble, and locally bundled LaTeX packages. Charts are generated by a
# Python script and gated on a sentinel so editing the Markdown alone does not
# redraw them.
#
# Override REPORT to point at your own Markdown file:
#   make REPORT=path/to/doc.md
# The default builds the fabricated test fixture under test/.

REPORT      ?= test/REPORT.md
CHARTS_DIR  ?= test/charts
PLOT        ?= $(CHARTS_DIR)/plot_findings.py
PYTHON      ?= python3
OUT         := $(basename $(notdir $(REPORT))).pdf

PANDOC_MAINFONT ?= TeX Gyre Pagella
PANDOC_SANSFONT ?= TeX Gyre Heros
PANDOC_MONOFONT ?= DejaVu Sans Mono

LOCAL_STYS := fvextra.sty upquote.sty widows-and-orphans.sty needspace.sty
CHARTS_STAMP := $(CHARTS_DIR)/.stamp

.PHONY: all charts clean rebuild
all: $(OUT)
	@echo "==> built $(OUT)"

# ---- charts ----
charts: $(CHARTS_STAMP)

$(CHARTS_STAMP): $(PLOT)
	$(PYTHON) $(PLOT)
	@touch $@

# ---- PDF ----
$(OUT): $(REPORT) header.tex filter.lua $(LOCAL_STYS) $(CHARTS_STAMP)
	TEXINPUTS=.:$$TEXINPUTS pandoc $(REPORT) \
		--from markdown+raw_tex+raw_attribute-smart \
		--pdf-engine=lualatex \
		--resource-path=.:$(dir $(REPORT)):$(CHARTS_DIR) \
		--lua-filter=filter.lua \
		--include-in-header=header.tex \
		--toc --toc-depth=2 \
		-V mainfont="$(PANDOC_MAINFONT)" \
		-V mainfontoptions:RawFeature=-tlig \
		-V sansfont="$(PANDOC_SANSFONT)" \
		-V sansfontoptions:RawFeature=-tlig \
		-V monofont="$(PANDOC_MONOFONT)" \
		-V documentclass=article \
		-V fontsize=10pt \
		-V linkcolor=accent \
		-o $(OUT)

clean:
	rm -f $(OUT) *.aux *.log *.toc *.out $(CHARTS_STAMP)

rebuild:
	rm -f $(OUT) $(CHARTS_STAMP)
	$(MAKE) $(OUT)
